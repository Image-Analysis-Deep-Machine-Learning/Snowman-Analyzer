<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" Width="1920" Height="1080"
        xmlns:dataContext="using:Snowman.DataContexts"
        xmlns:ctrl="using:Snowman.Controls"
        xmlns:snowman="using:Snowman"
        x:Class="Snowman.MainWindow"
        x:DataType="dataContext:MainWindowDataContext"
        Title="Snowman"
        WindowState="Maximized"
        Background="#1e1f22">
    <Window.DataContext><dataContext:MainWindowDataContext></dataContext:MainWindowDataContext></Window.DataContext>
    <Window.Resources>
        <StreamGeometry x:Key="ArrowLeftRegular">M12.7347,4.20949 C13.0332,3.92233 13.508,3.93153 13.7952,4.23005 C14.0823,4.52857 14.0731,5.00335 13.7746,5.29051 L5.50039,13.25 L24.2532,13.25 C24.6674,13.25 25.0032,13.5858 25.0032,13.9999982 C25.0032,14.4142 24.6674,14.75 24.2532,14.75 L5.50137,14.75 L13.7746,22.7085 C14.0731,22.9957 14.0823,23.4705 13.7952,23.769 C13.508,24.0675 13.0332,24.0767 12.7347,23.7896 L3.30673,14.7202 C2.89776,14.3268 2.89776,13.6723 3.30673,13.2788 L12.7347,4.20949 Z</StreamGeometry>
        <StreamGeometry x:Key="ArrowRightRegular">M15.2685,4.20949 C14.97,3.92233 14.4952,3.93153 14.208,4.23005 C13.9209,4.52857 13.9301,5.00335 14.2286,5.29051 L22.5028,13.25 L3.75,13.25 C3.33579,13.25 3,13.5858 3,13.9999982 C3,14.4142 3.33579,14.75 3.75,14.75 L22.5018,14.75 L14.2286,22.7085 C13.9301,22.9957 13.9209,23.4705 14.208,23.769 C14.4952,24.0675 14.97,24.0767 15.2685,23.7896 L24.6965,14.7202 C25.1054,14.3268 25.1054,13.6723 24.6965,13.2788 L15.2685,4.20949 Z</StreamGeometry>
    </Window.Resources>
    <Grid RowDefinitions="Auto, *, Auto">
        <!-- menu -->
        <Menu Grid.Row="0" Background="#2b2d30">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project" Command ="{Binding NewProject}"/>
                <MenuItem Header="_Open Project" Command ="{Binding OpenProject}"/>
                <MenuItem Header="_Save Project" Command ="{Binding SaveProject}"/>
                <MenuItem Header="_Open Dataset" Command="{Binding OpenXml}"/>
                <MenuItem Header="_Settings"/>
                <Separator/>
                <MenuItem Header="_Load Video File" Command="{Binding LoadVideoFile}"/>
                <Separator/>
                <MenuItem Header="_Exit" Command="{Binding $parent[snowman:MainWindow].Close}"/>
            </MenuItem>
        </Menu>
        
        <!-- main display window -->
        <Grid Grid.Row="1" RowDefinitions="7*,3*" ColumnDefinitions="7*,3*" Margin="5, 5" HorizontalAlignment="Stretch">
            <!-- viewport -->
            <Border Grid.Row="0" Grid.Column="0"  BorderBrush="#4b4c4e" BorderThickness="4" CornerRadius="3">
                <ctrl:ViewportWindow HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            </Border>
            
            <!-- timeline container -->
            <Grid Grid.Row="1" Grid.Column="0" Margin="0, 5, 0, 0">
                <Grid Name="FrameTimelineGrid" RowDefinitions="*" ColumnDefinitions="Auto,*,Auto">
                    <!-- prev -->
                    <Button Grid.Column="0" Command="{Binding PrevFrame}">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <Path Data="{StaticResource ArrowLeftRegular}" Fill="White" Margin="0, 0, 0, 10"/>
                            <TextBlock Text="Prev" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- frame timeline -->
                    <Border Grid.Column="1" Margin="5, 0, 5, 0">
                        <ctrl:FrameTimeline Name="FrameTimeline"/>
                    </Border>
                    
                    <!-- next -->
                    <Button Grid.Column="2" Command="{Binding NextFrame}">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <Path Data="{StaticResource ArrowRightRegular}" Fill="White" Margin="0, 0, 0, 10"/>
                            <TextBlock Text="Next" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
                
                <!-- event timeline -->
                <Border Name="EventTimelineBorder" IsVisible="False" Margin="10, 0, 10, 0">
                    <ctrl:EventTimeline/>
                </Border>
                
                <!-- zoom -->
                <ComboBox
                    Name="ZoomComboBox"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom" ZIndex="100"
                    ItemsSource="{Binding ZoomScaleOptions}"
                    SelectedItem="{Binding  ZoomScaleString, Mode=TwoWay}"
                    Width="75" MinHeight="15" FontSize="12"
                    Background="Transparent" BorderBrush="Transparent"
                    HorizontalContentAlignment="Right"
                    IsVisible="False">
                    <ComboBox.Styles>
                        <Style Selector="ComboBox:pointerover /template/ Border">
                            <Setter Property="Background" Value="#4b4c4e"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                        <Style Selector="ComboBox:pressed /template/ Border">
                            <Setter Property="Background" Value="#4b4c4e"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                        <Style Selector="ComboBox:dropdownopen /template/ Border">
                            <Setter Property="Background" Value="#4b4c4e"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                    </ComboBox.Styles>
                </ComboBox>
                
                <!-- timeline toggle buttons -->
                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Top" ZIndex="100">
                    
                    <!-- frame timeline -->
                    <Button Name="ToggleFrameTimelineButton" Width="24" Height="24" Margin="0, 0, 5, 0" Click="ToggleFrameTimelineButton_OnClick" ToolTip.Tip="Frame Timeline">
                        <Path Name="FrameTimelinePath"
                            Data="{StaticResource FrameTimelineIcon}"
                            Fill="{DynamicResource SystemAccentColor}"
                            Stretch="Uniform"
                            Width="16" Height="16"
                            VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    
                    <!-- event timeline -->
                    <Button Name="ToggleEventTimelineButton" Width="24" Height="24" Click="ToggleEventTimelineButton_OnClick" ToolTip.Tip="Event Timeline">
                        <Path Name="EventTimelinePath"
                              Data="{StaticResource EventTimelineIcon}"
                              Fill="White"
                              Stretch="Uniform"
                              Width="16" Height="16"
                              VerticalAlignment="Center" HorizontalAlignment="Center">
                        </Path>
                    </Button>
                </StackPanel>
            </Grid>
            
            <!-- run script -->
            <DockPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" IsVisible="{Binding IsEntitySelected}">
                <DockPanel DockPanel.Dock="Top">
                    <Label Content="Scripts to run:" Margin="10" VerticalAlignment="Center"></Label>
                </DockPanel>
                <DockPanel DockPanel.Dock="Top">
                    <Label Margin="10" VerticalAlignment="Center">ID:</Label>
                    <TextBox HorizontalAlignment="Stretch" Margin="10" Text="{Binding }"></TextBox>
                </DockPanel>
                <!-- <Button DockPanel.Dock="Top" VerticalAlignment="Top" Margin="10, 0, 10, 10" Content="Run Demo Script" Command="{Binding Demo}"></Button> -->
                <TextBox TextWrapping="Wrap" Classes="TextArea" VerticalAlignment="Stretch" DockPanel.Dock="Top" Margin="10, 0, 10, 5" AcceptsReturn="True" Name="DemoOutput"></TextBox>
            </DockPanel>
            <DockPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" Margin="10, 5, 10, 10">
                <Button DockPanel.Dock="Bottom" VerticalAlignment="Top" Margin="10, 10, 10, 0" Content="Clear Event Info" Command="{Binding ClearEventInfo}"></Button>
                <TextBox DockPanel.Dock="Top" Name="InfoBox" TextWrapping="Wrap" Classes="TextArea" VerticalAlignment="Stretch"></TextBox>
            </DockPanel>
        </Grid>
        
        <!-- bottom bar -->
        <Border Grid.Row="2" Background="#2b2d30" Padding="5" Height="25">
            <!-- progress bar -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <ProgressBar Height="15" MaxWidth="200"
                             x:Name="ProgressBar"
                             Minimum="0" Maximum="100" Value="0"
                             ShowProgressText="True"
                             IsVisible="False"/>
                <TextBlock Height="15" FontSize="12" Margin="5, 0 , 0, 0" x:Name="ProgressBarText" IsVisible="False"></TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
