<ctrl:ServiceableUserControl x:TypeArguments="dataContext:ViewportWindowDataContext"
                             xmlns="https://github.com/avaloniaui"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                             x:Class="Snowman.Controls.ViewportWindow"
                             xmlns:dataContext="clr-namespace:Snowman.DataContexts"
                             xmlns:ctrl="clr-namespace:Snowman.Controls"
                             x:DataType="dataContext:ViewportWindowDataContext"
                             x:Name="Root">
    <!-- This line is to prevent the Binding compiler to mess with the DataContext types and throw exceptions for no reason -->
    <ctrl:ServiceableUserControl.DataContext><dataContext:ViewportWindowDataContext/></ctrl:ServiceableUserControl.DataContext>
    <Grid RowDefinitions="35,*" HorizontalAlignment="Stretch">
        <ctrl:ToolBar ServiceProvider="{Binding #Root.ServiceProvider}" Grid.Row="0" Name="ToolBar"></ctrl:ToolBar>
        <Panel Grid.Row="1">
            <ctrl:Viewport ServiceProvider="{Binding #Root.ServiceProvider}" Name="Viewport"></ctrl:Viewport>
        </Panel>
    </Grid>
</ctrl:ServiceableUserControl>
