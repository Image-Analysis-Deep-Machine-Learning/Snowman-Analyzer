<ctrl:ServiceableUserControl x:TypeArguments="dataContexts:ViewportWindowDataContext" xmlns="https://github.com/avaloniaui"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                             xmlns:dataContexts="clr-namespace:Snowman.DataContexts"
                             xmlns:ctrl="clr-namespace:Snowman.Controls"
                             x:Class="Snowman.Controls.ViewportWindow"
                             x:DataType="dataContexts:ViewportWindowDataContext">
    <ctrl:ServiceableUserControl.DataContext>
        <dataContexts:ViewportWindowDataContext></dataContexts:ViewportWindowDataContext>
    </ctrl:ServiceableUserControl.DataContext>
    
    <Grid RowDefinitions="35,*" HorizontalAlignment="Stretch">
        <ctrl:ToolBar ServiceProvider="{Binding $parent[ctrl:ViewportWindow].ServiceProvider}" Grid.Row="0" Name="ToolBar"></ctrl:ToolBar>
        <Panel Grid.Row="1">
            <ctrl:Viewport ServiceProvider="{Binding $parent[ctrl:ViewportWindow].ServiceProvider}" Name="Viewport"></ctrl:Viewport>
        </Panel>
    </Grid>
</ctrl:ServiceableUserControl>
