<ctrl:UserControlWrapper x:TypeArguments="dataContext:ViewportWindowDataContext"
                         xmlns="https://github.com/avaloniaui"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                         mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                         x:Class="Snowman.Controls.ViewportWindow"
                         xmlns:dataContext="using:Snowman.DataContexts"
                         xmlns:ctrl="using:Snowman.Controls"
                         x:DataType="dataContext:ViewportWindowDataContext"
                         x:Name="Root">
    <Grid RowDefinitions="35,*" HorizontalAlignment="Stretch">
        <ctrl:ToolBar Grid.Row="0" Name="ToolBar"/>
        <Panel Grid.Row="1">
            <ctrl:Viewport Name="Viewport" Background="Transparent"/>
        </Panel>
    </Grid>
</ctrl:UserControlWrapper>
