<ctrl:UserControlWrapper x:TypeArguments="dataContext:NodeControlDataContext"
                         xmlns="https://github.com/avaloniaui"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                         mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                         x:Class="Snowman.Controls.NodeControl"
                         xmlns:dataContext="using:Snowman.DataContexts"
                         xmlns:ctrl="using:Snowman.Controls"
                         x:DataType="dataContext:NodeControlDataContext"
                         ClipToBounds="False">
    <Border Background="{DynamicResource SemiColorDisabledBorder}"
            CornerRadius="5"
            BoxShadow="5 5 25 0 Black"
            BorderBrush="Black"
            BorderThickness="1">
        <StackPanel Margin="-6.5, 0">
            <Expander BorderThickness="-1"
                      Header="{Binding NodeName}"
                      Background="Transparent"
                      BorderBrush="Transparent"
                      Classes="MainNodeExpander"
                      IsExpanded="True">
                <StackPanel Name="MainGroup"/>
            </Expander>
        </StackPanel>
    </Border>
</ctrl:UserControlWrapper>
