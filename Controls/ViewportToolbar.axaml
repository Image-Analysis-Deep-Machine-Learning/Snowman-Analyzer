<ctrl:UserControlWrapper x:TypeArguments="dataContext:ViewportToolbarDataContext"
                         xmlns="https://github.com/avaloniaui"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                         mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                         x:Class="Snowman.Controls.ViewportToolbar"
                         xmlns:dataContext="using:Snowman.DataContexts"
                         xmlns:ctrl="using:Snowman.Controls"
                         x:DataType="dataContext:ViewportToolbarDataContext"
                         x:Name="Root">
    <ItemsControl ItemsSource="{Binding Tools}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="5"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Button Content="{Binding Name}"
                        Command="{Binding #Root.DataContext.SetTool}"
                        CommandParameter="{Binding}"
                        Foreground="{StaticResource SystemAccentColor}"/>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</ctrl:UserControlWrapper>
