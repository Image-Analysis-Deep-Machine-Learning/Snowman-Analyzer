<ctrl:UserControlWrapper x:TypeArguments="dataContext:NodePortDataContext"
                         xmlns="https://github.com/avaloniaui"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                         mc:Ignorable="d" d:DesignWidth="11" d:DesignHeight="11"
                         x:Class="Snowman.Controls.NodePort"
                         xmlns:dataContext="using:Snowman.DataContexts"
                         xmlns:ctrl="using:Snowman.Controls">
    <Panel Width="11" Height="11">
        <Ellipse Fill="Aquamarine" Stroke="Black" StrokeThickness="1" Width="10" Height="10"/>
    </Panel>
</ctrl:UserControlWrapper>
