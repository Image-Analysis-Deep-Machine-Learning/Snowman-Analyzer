<ctrl:UserControlWrapper x:TypeArguments="dataContext:EventTimelineDataContext" xmlns="https://github.com/avaloniaui"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                             x:Class="Snowman.Controls.EventTimeline"
                             xmlns:dataContext="using:Snowman.DataContexts"
                             xmlns:ctrl="using:Snowman.Controls"
                             x:DataType="dataContext:EventTimelineDataContext">
    <ctrl:UserControlWrapper.DataContext><dataContext:EventTimelineDataContext></dataContext:EventTimelineDataContext></ctrl:UserControlWrapper.DataContext>
    <Canvas x:Name="Canvas"/>
</ctrl:UserControlWrapper>
