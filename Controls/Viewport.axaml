<controls:ServiceableUserControl x:TypeArguments="dataContexts:ViewportDataContext"
                                 xmlns="https://github.com/avaloniaui"
                                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                                 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                                 x:Class="Snowman.Controls.Viewport"
                                 xmlns:dataContexts="clr-namespace:Snowman.DataContexts"
                                 xmlns:controls="clr-namespace:Snowman.Controls"
                                 x:DataType="dataContexts:ViewportDataContext"
                                 Bounds="{Binding ControlBounds, Mode=OneWayToSource}">
    <controls:ServiceableUserControl.DataContext>
        <dataContexts:ViewportDataContext></dataContexts:ViewportDataContext>
    </controls:ServiceableUserControl.DataContext>
</controls:ServiceableUserControl>
