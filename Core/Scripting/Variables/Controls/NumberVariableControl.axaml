<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:snowman="using:Snowman.Core.Scripting.Variables"
             mc:Ignorable="d"
             x:Class="Snowman.Core.Scripting.Variables.Controls.NumberVariableControl"
             x:DataType="snowman:NumberVariable">
    <StackPanel Orientation="Horizontal">
        <Label Content="{Binding FriendlyName}" VerticalContentAlignment="Center" Margin="0 0 5 0"/>
        <NumericUpDown HorizontalAlignment="Stretch" Value="{Binding Value}"/>
    </StackPanel>
</UserControl>
